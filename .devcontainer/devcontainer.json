{
  "name": "G0I Premium AI Environment",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {},
    "ghcr.io/devcontainers/features/python:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "continue.continue",
        "ms-python.python",
        "dsznajder.es7-react-js-snippets"
      ],
      "settings": {
        "continue.apiBase": "https://api.g0i.ai/v1"
      }
    }
  },
  "postCreateCommand": "pip install aider-chat"
}